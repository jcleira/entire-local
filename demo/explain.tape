# entire explain -c <checkpoint>
Output demo/explain.gif
Source demo/settings.tape

Type "./entire-local"
Enter
Sleep 2s

# Navigate to checkpoint and enter detail
Type "j"
Sleep 300ms
Enter
Sleep 2s

# Open action menu and navigate to explain (2nd item)
Type "a"
Sleep 1s
Type "j"
Sleep 400ms
Enter
Sleep 5s

# TUI resumes after command finishes
Sleep 2s

Type "q"
