# entire status --detailed
Output demo/status.gif
Source demo/settings.tape

Type "./entire-local"
Enter
Sleep 2s

# Open action menu and navigate to status (first item)
Type "a"
Sleep 1s
Enter
Sleep 3s

# Scroll through output
Type "j"
Sleep 300ms
Type "j"
Sleep 300ms
Type "j"
Sleep 300ms
Type "k"
Sleep 300ms
Type "k"
Sleep 1s

# Close output
Escape
Sleep 1s

Type "q"
